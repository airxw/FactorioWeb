<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>控制面板 - Factorio Server Pro</title>
    <link rel="stylesheet" href="/lib/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/lib/vendor/xterm/css/xterm.css">
    <link rel="stylesheet" href="/lib/vendor/bootstrap/bootstrap-icons.css">
    <link id="skin-style" rel="stylesheet" href="/app/public/assets/skins/default.css">
    <link rel="stylesheet" href="/app/public/assets/css/main.css">
    <style>
        :root {
            --sidebar-width: 220px;
        }
        body {
            background: #f8f9fa;
            min-height: 100vh;
        }
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }
        .sidebar-header {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            flex-shrink: 0;
        }
        .sidebar-nav {
            padding: 0.5rem 0;
            flex: 1;
            overflow-y: auto;
        }
        .sidebar-nav-item {
            display: block;
            padding: 0.65rem 1.25rem;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            transition: all 0.2s;
            font-size: 0.9rem;
            border-left: 3px solid transparent;
        }
        .sidebar-nav-item:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.9);
        }
        .sidebar-nav-item.active {
            background: rgba(255,255,255,0.12);
            color: white;
            border-left-color: #4dabf7;
        }
        .sidebar-nav-item i {
            width: 20px;
            margin-right: 10px;
            font-size: 0.95rem;
        }
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }
        .view-panel {
            display: none;
            padding: 1.5rem 2rem;
        }
        .view-panel.active {
            display: block;
        }
        .user-dropdown {
            position: sticky;
            bottom: 0;
            background: rgba(26,26,46,0.95);
            backdrop-filter: blur(8px);
            padding: 0.75rem 1rem;
            border-top: 1px solid rgba(255,255,255,0.08);
            flex-shrink: 0;
        }
        .nav-section-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.35);
            padding: 0.75rem 1.25rem 0.35rem;
            font-weight: 600;
        }

        .page-header {
            margin-bottom: 1.25rem;
        }
        .page-header h4 { margin-bottom: 0.15rem; }
        .page-header p { margin-bottom: 0; color: #6c757d; font-size: 0.875rem; }

        .card { border-radius: 0.75rem; }
        .card-header { font-weight: 600; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-header">
        <div class="d-flex align-items-center">
            <i class="bi bi-hdd-rack-fill fs-4 me-2"></i>
            <span class="fw-bold fs-5">Factorio Pro</span>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-title">服务器管理</div>
        <a href="#" class="sidebar-nav-item active" data-view="control">
            <i class="bi bi-play-circle"></i>控制
        </a>
        <a href="#" class="sidebar-nav-item" data-view="mods">
            <i class="bi bi-puzzle"></i>模组
        </a>
        <a href="#" class="sidebar-nav-item" data-view="players">
            <i class="bi bi-people"></i>玩家
        </a>
        <a href="#" class="sidebar-nav-item" data-view="responder">
            <i class="bi bi-robot"></i>交互
        </a>
        <a href="#" class="sidebar-nav-item" data-view="files">
            <i class="bi bi-folder2-open"></i>文件
        </a>
        <a href="#" class="sidebar-nav-item" data-view="logs">
            <i class="bi bi-journal-text"></i>日志
        </a>

        <div class="nav-section-title mt-2">系统</div>
        <a href="#" class="sidebar-nav-item" data-view="settings">
            <i class="bi bi-gear"></i>系统设置
        </a>
    </nav>

    <div class="user-dropdown">
        <div class="d-flex align-items-center">
            <i class="bi bi-person-circle fs-4 me-2 opacity-75"></i>
            <div class="flex-grow-1">
                <div class="small fw-bold" id="current-user">管理员</div>
                <div class="small opacity-50" style="font-size:0.72rem">在线</div>
            </div>
            <button class="btn btn-sm btn-outline-light" onclick="logout()" title="退出" style="font-size:0.7rem; padding:0.2rem 0.45rem;">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </div>
    </div>
</div>

<div class="main-content">

    <!-- ========== 控制 ========== -->
    <div id="view-control" class="view-panel active">
        <div class="page-header d-flex justify-content-between align-items-center">
            <div>
                <h4><i class="bi bi-play-circle me-2 text-primary"></i>服务器控制</h4>
                <p class="text-muted mb-0 small">启动、停止、存档管理您的 Factorio 服务端</p>
            </div>
            <span id="server-status-badge" class="badge bg-secondary"><i class="bi bi-circle me-1"></i>检测中...</span>
        </div>

        <div id="stop-area" class="d-none">
            <div class="card border-success bg-success bg-opacity-10 mb-4">
                <div class="card-body text-center py-4">
                    <div class="mb-3 text-success"><i class="bi bi-check-circle-fill display-4"></i></div>
                    <h5 class="fw-bold text-success mb-3">服务器正常运行中</h5>
                    <div class="d-flex gap-2 justify-content-center">
                        <button onclick="saveGame()" class="btn btn-success"><i class="bi bi-save me-1"></i>存档</button>
                        <button onclick="controlServer('stop')" class="btn btn-danger"><i class="bi bi-power me-1"></i>停止</button>
                    </div>
                </div>
            </div>
        </div>

        <form id="startForm" class="d-none">
            <div class="card mb-4">
                <div class="card-header"><i class="bi bi-sliders me-2"></i>启动配置</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">服务端版本</label>
                        <div class="input-group">
                            <select name="version" id="version-select" class="form-select"></select>
                            <button type="button" class="btn btn-light border" onclick="checkUpdate()" title="检查更新"><i class="bi bi-cloud-arrow-down"></i></button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">地图存档 (.zip)</label>
                        <div class="input-group">
                            <select name="map" id="map-select" class="form-select"><option disabled>加载中...</option></select>
                            <button type="button" class="btn btn-light border" onclick="refreshMapList()"><i class="bi bi-arrow-repeat"></i></button>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">配置文件 (.json)</label>
                        <div class="input-group">
                            <select name="config" id="config-select" class="form-select" onchange="updateConfigEditLink()"><option disabled>加载中...</option></select>
                            <a href="../../configEditor.php" target="_blank" id="config-edit-link" class="btn btn-light border" title="编辑配置"><i class="bi bi-pencil"></i></a>
                            <button type="button" class="btn btn-light border" onclick="refreshConfigList()"><i class="bi bi-arrow-repeat"></i></button>
                        </div>
                    </div>
                    <button type="button" onclick="controlServer('start')" class="btn btn-primary w-100 py-2"><i class="bi bi-play-fill me-1"></i>启动服务器</button>
                </div>
            </div>
        </form>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history me-2"></i>历史存档（点击切换/回档）</span>
                <button class="btn btn-sm btn-outline-secondary" onclick="refreshMapList()"><i class="bi bi-arrow-repeat"></i></button>
            </div>
            <div class="list-group list-group-flush" id="save-history" style="max-height:300px;overflow-y:auto"></div>
        </div>
    </div>

    <!-- ========== 模组 ========== -->
    <div id="view-mods" class="view-panel">
        <div class="page-header">
            <h4><i class="bi bi-puzzle me-2 text-warning"></i>模组管理</h4>
            <p class="text-muted mb-0 small">安装、启用、禁用游戏模组</p>
        </div>

        <button class="btn btn-success w-100 mb-3" data-bs-toggle="modal" data-bs-target="#modPortalModal"><i class="bi bi-cloud-download me-2"></i>打开 Mod 门户</button>

        <div class="card mb-3">
            <div class="card-body p-2">
                <div class="input-group input-group-sm">
                    <input type="file" id="mod-upload-input" class="form-control" multiple accept=".zip">
                    <button class="btn btn-primary" onclick="uploadMod()">本地上传</button>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="fw-bold small text-muted">已安装列表</span>
            <div class="input-group input-group-sm w-50">
                <input type="text" id="local-mod-filter" class="form-control" placeholder="筛选..." onkeyup="filterLocalMods()">
                <button class="btn btn-light border" onclick="loadMods()"><i class="bi bi-arrow-repeat"></i></button>
            </div>
        </div>
        <div id="mod-list" class="bg-white border rounded" style="min-height: 200px; max-height: 500px; overflow-y: auto;"></div>
    </div>

    <!-- ========== 玩家 ========== -->
    <div id="view-players" class="view-panel">
        <div class="page-header">
            <h4><i class="bi bi-people me-2 text-info"></i>玩家管理</h4>
            <p class="text-muted mb-0 small">封禁、踢出、白名单、物品给予</p>
        </div>

        <div class="position-relative mb-3">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" id="target-player" class="form-control" placeholder="输入玩家名或IP搜索..." autocomplete="off">
                <button class="btn btn-outline-secondary" onclick="loadPlayerLists()"><i class="bi bi-arrow-repeat"></i></button>
            </div>
            <div id="player-dropdown" class="dropdown-menu w-100" style="max-height: 300px; overflow-y: auto; display: none;">
                <div class="dropdown-header d-flex justify-content-between align-items-center">
                    <span>已知玩家列表</span>
                    <small class="text-muted">点击选择</small>
                </div>
                <div id="player-dropdown-items"></div>
            </div>
        </div>

        <div class="row g-2 mb-4">
            <div class="col-6"><button class="btn btn-outline-danger w-100" onclick="doAction('ban')">封禁 (Ban)</button></div>
            <div class="col-6"><button class="btn btn-outline-warning w-100" onclick="doAction('kick')">踢出 (Kick)</button></div>
            <div class="col-6"><button class="btn btn-outline-success w-100" onclick="doAction('promote')">设为管理</button></div>
            <div class="col-6"><button class="btn btn-outline-secondary w-100" onclick="doAction('unban')">解封</button></div>
            <div class="col-6"><button class="btn btn-outline-primary w-100" onclick="doAction('wl-add')">+ 加白名单</button></div>
            <div class="col-6"><button class="btn btn-outline-dark w-100" onclick="doAction('wl-remove')">- 移出白名单</button></div>
        </div>

        <div class="card border-info mb-4">
            <div class="card-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%); color: white;">
                <span><i class="bi bi-gift me-2"></i>给予物品</span>
                <button class="btn btn-sm btn-light py-0 fw-bold" style="color: #0aa2c0;" data-bs-toggle="modal" data-bs-target="#itemModal">打开物品库</button>
            </div>
            <div class="card-body bg-light">
                <div class="input-group mb-2">
                    <span class="input-group-text bg-white">物品代码</span>
                    <input type="text" id="gift-item" class="form-control" placeholder="例如: iron-plate">
                </div>
                <div class="input-group">
                    <span class="input-group-text bg-white">数量</span>
                    <input type="number" id="gift-count" class="form-control" value="100" min="1">
                    <button class="btn btn-info text-white" onclick="doGift()">发送</button>
                </div>
            </div>
        </div>

        <div class="card border-success mb-3">
            <div class="card-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #198754 0%, #157347 100%); color: white;">
                <span><i class="bi bi-people-fill me-2"></i>已知玩家（日志分析）</span>
                <small style="opacity: 0.8;">点击选择玩家</small>
            </div>
            <div class="card-body p-0">
                <div id="known-players-list" class="list-group list-group-flush" style="max-height: 250px; overflow-y: auto;">
                    <div class="text-center text-muted small p-3">暂无玩家数据，等待玩家登录...</div>
                </div>
            </div>
        </div>

        <div class="accordion accordion-flush border rounded" id="plAcc">
            <div class="accordion-item"><h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#ls-admin">管理员</button></h2><div id="ls-admin" class="accordion-collapse collapse" data-bs-parent="#plAcc"><div class="list-group list-group-flush" id="list-admins"></div></div></div>
            <div class="accordion-item"><h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#ls-white">白名单</button></h2><div id="ls-white" class="accordion-collapse collapse" data-bs-parent="#plAcc"><div class="list-group list-group-flush" id="list-whitelist"></div></div></div>
            <div class="accordion-item"><h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#ls-ban">封禁名单</button></h2><div id="ls-ban" class="accordion-collapse collapse" data-bs-parent="#plAcc"><div class="list-group list-group-flush" id="list-bans"></div></div></div>
        </div>
    </div>

    <!-- ========== 交互（自动响应） ========== -->
    <div id="view-responder" class="view-panel">
        <div class="page-header">
            <h4><i class="bi bi-robot me-2 text-purple"></i>自动响应系统</h4>
            <p class="text-muted mb-0 small">周期消息、关键词回复、玩家事件、投票踢人等</p>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-robot me-2"></i>自动响应系统
                    <span id="auto-responder-status-badge" class="badge bg-secondary ms-2">检查中...</span>
                </div>
                <button id="btn-toggle-auto-responder" class="btn btn-sm btn-success" onclick="toggleAutoResponder()">
                    <i class="bi bi-power me-1"></i>启动
                </button>
            </div>
            <div class="card-body">
                <ul class="nav nav-tabs nav-fill mb-3" id="chatSettingsTabs" role="tablist">
                    <li class="nav-item"><button class="nav-link active" id="periodic-tab" data-bs-toggle="tab" data-bs-target="#periodic-panel" role="tab">服务器响应</button></li>
                    <li class="nav-item"><button class="nav-link" id="scheduled-tab" data-bs-toggle="tab" data-bs-target="#scheduled-panel" role="tab">定时任务</button></li>
                    <li class="nav-item"><button class="nav-link" id="trigger-tab" data-bs-toggle="tab" data-bs-target="#trigger-panel" role="tab">关键词回复</button></li>
                    <li class="nav-item"><button class="nav-link" id="event-tab" data-bs-toggle="tab" data-bs-target="#event-panel" role="tab">玩家事件</button></li>
                </ul>

                <div class="tab-content" id="chatSettingsTabContent">
                    <div class="tab-pane fade show active" id="periodic-panel" role="tabpanel">
                        <div class="mb-3">
                            <h6 class="text-muted">服务器功能响应</h6>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">响应类型</label>
                                <div class="input-group mb-2">
                                    <select id="server-response-type" class="form-select form-select-sm" style="max-width: 200px;">
                                        <option value="vote-kick">发起投票踢人</option>
                                        <option value="server-info">服务器信息</option>
                                        <option value="ping-test">延迟测试</option>
                                        <option value="restart-warning">重启警告</option>
                                        <option value="request-item">向腐竹讨要物品</option>
                                        <option value="custom">自定义命令</option>
                                    </select>
                                    <button class="btn btn-sm btn-outline-primary" onclick="addServerResponse()">添加</button>
                                </div>
                            </div>
                            <div id="response-config" style="display: none;">
                                <label class="form-label small fw-bold text-muted">配置参数</label>
                                <div id="vote-kick-config" class="response-config-content">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="触发关键词（例如：!votekick）">
                                        <input type="number" class="form-control form-control-sm" placeholder="所需票数" min="1" max="10">
                                    </div>
                                    <div class="input-group mb-2">
                                        <input type="number" class="form-control form-control-sm" placeholder="投票超时时间（秒）" min="30" max="300">
                                        <input type="number" class="form-control form-control-sm" placeholder="冷却时间（秒）" min="60" max="1800">
                                    </div>
                                </div>
                                <div id="ping-test-config" class="response-config-content" style="display: none;">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="触发关键词（例如：!ping）">
                                    </div>
                                </div>
                                <div id="server-info-config" class="response-config-content" style="display: none;">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="触发关键词（例如：!server）">
                                    </div>
                                </div>
                                <div id="restart-warning-config" class="response-config-content" style="display: none;">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="触发关键词（例如：!restart）">
                                        <input type="number" class="form-control form-control-sm" placeholder="警告时间（分钟）" min="1" max="60">
                                    </div>
                                </div>
                                <div id="custom-config" class="response-config-content" style="display: none;">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="触发关键词">
                                        <input type="text" class="form-control form-control-sm" placeholder="执行命令">
                                    </div>
                                </div>
                                <div id="request-item-config" class="response-config-content" style="display: none;">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="触发关键词（例如：!give）">
                                        <input type="number" class="form-control form-control-sm" placeholder="给予数量（默认100）" min="1" max="10000" value="100">
                                    </div>
                                    <div class="input-group mb-2">
                                        <input type="number" class="form-control form-control-sm" placeholder="冷却时间（秒）" min="0" max="86400" value="60">
                                    </div>
                                </div>
                            </div>
                            <div id="periodic-list" class="mt-2 border rounded p-2" style="max-height: 280px; overflow-y: auto;">
                                <div class="text-muted text-sm" id="periodic-list-empty">暂无服务器响应设置</div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="scheduled-panel" role="tabpanel">
                        <div class="mb-3">
                            <h6 class="text-muted">定时发送</h6>
                            <div class="input-group mb-2">
                                <input type="text" id="schedule-message" class="form-control form-control-sm" placeholder="定时消息内容">
                                <input type="time" id="schedule-time" class="form-control form-control-sm" style="max-width: 100px;">
                                <select id="schedule-repeat" class="form-select form-select-sm" style="max-width: 120px;">
                                    <option value="once">仅一次</option>
                                    <option value="seconds">每__秒</option>
                                    <option value="minutes">每__分钟</option>
                                    <option value="hours">每__小时</option>
                                    <option value="daily">每天</option>
                                    <option value="weekly">每周</option>
                                </select>
                                <input type="number" id="schedule-interval" class="form-control form-control-sm" style="max-width: 80px; display: none;" placeholder="间隔" min="1">
                                <button class="btn btn-sm btn-outline-primary" onclick="scheduleChatMessage()">添加</button>
                            </div>
                            <div id="scheduled-list" class="mt-2 border rounded p-2" style="max-height: 280px; overflow-y: auto;">
                                <div class="text-muted text-sm" id="scheduled-list-empty">暂无定时任务</div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="trigger-panel" role="tabpanel">
                        <div class="mb-3">
                            <h6 class="text-muted">关键词自动回复</h6>
                            <div class="input-group mb-2">
                                <input type="text" id="trigger-keyword" class="form-control form-control-sm" placeholder="触发关键词">
                                <input type="text" id="trigger-response" class="form-control form-control-sm" placeholder="响应内容（可用 {player} 表示玩家名）">
                                <button class="btn btn-sm btn-outline-primary" onclick="addTriggerResponse()">添加</button>
                            </div>
                            <div id="trigger-list" class="mt-2 border rounded p-2" style="max-height: 280px; overflow-y: auto;">
                                <div class="text-muted text-sm" id="trigger-list-empty">暂无已添加的条件发送</div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="event-panel" role="tabpanel">
                        <div class="mb-3">
                            <h6 class="text-muted">玩家事件自动响应</h6>
                            <div class="mb-3 p-2 border rounded">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="welcome-enabled" onchange="updatePlayerEvents()">
                                    <label class="form-check-label" for="welcome-enabled">玩家上线欢迎</label>
                                </div>
                                <input type="text" id="welcome-message" class="form-control form-control-sm" placeholder="欢迎消息（可用 {player} 表示玩家名）" onchange="updatePlayerEvents()">
                            </div>
                            <div class="mb-3 p-2 border rounded">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="goodbye-enabled" onchange="updatePlayerEvents()">
                                    <label class="form-check-label" for="goodbye-enabled">玩家下线告别</label>
                                </div>
                                <input type="text" id="goodbye-message" class="form-control form-control-sm" placeholder="告别消息（可用 {player} 表示玩家名）" onchange="updatePlayerEvents()">
                            </div>
                            <div class="mb-3 p-2 border rounded">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="first-join-gift-enabled" onchange="updatePlayerEvents()">
                                    <label class="form-check-label" for="first-join-gift-enabled">首次上线礼包</label>
                                </div>
                                <div id="first-join-gift-list" class="gift-items-list mb-2"></div>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openGiftItemSelector('first-join')"><i class="bi bi-plus-lg me-1"></i>添加物品</button>
                                </div>
                                <small class="text-muted">首次上线的玩家将获得这些物品</small>
                            </div>
                            <div class="mb-3 p-2 border rounded">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="rejoin-gift-enabled" onchange="updatePlayerEvents()">
                                    <label class="form-check-label" for="rejoin-gift-enabled">再次上线礼包</label>
                                </div>
                                <div id="rejoin-gift-list" class="gift-items-list mb-2"></div>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openGiftItemSelector('rejoin')"><i class="bi bi-plus-lg me-1"></i>添加物品</button>
                                </div>
                                <small class="text-muted">非首次上线的玩家将获得这些物品</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== 文件 ========== -->
    <div id="view-files" class="view-panel">
        <div class="page-header">
            <h4><i class="bi bi-folder2-open me-2 text-success"></i>文件管理</h4>
            <p class="text-muted mb-0 small">上传、下载、管理地图存档和配置文件</p>
        </div>

        <div class="card mb-3">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="fw-bold small text-muted">快速上传</label>
                    <span class="badge bg-light text-secondary border">支持 .zip / .json</span>
                </div>
                <div class="input-group">
                    <input type="file" id="file-upload" class="form-control" multiple accept=".zip,.json">
                    <button class="btn btn-primary" id="btn-upload"><i class="bi bi-upload"></i></button>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="fw-bold small text-muted mb-2 px-1">地图存档 (Saves)</div>
                <div id="file-list-map" class="list-group list-group-flush border rounded bg-white"></div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="fw-bold small text-muted mb-2 px-1">配置文件 (Configs)</div>
                <div id="file-list-config" class="list-group list-group-flush border rounded bg-white"></div>
            </div>
        </div>
    </div>

    <!-- ========== 日志 ========== -->
    <div id="view-logs" class="view-panel">
        <div class="page-header">
            <h4><i class="bi bi-journal-text me-2 text-danger"></i>日志管理</h4>
            <p class="text-muted mb-0 small">查看和管理历史日志文件</p>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-journal-text me-2"></i>历史日志管理</span>
                <button class="btn btn-sm btn-outline-primary" onclick="refreshLogList()"><i class="bi bi-arrow-repeat me-1"></i>刷新</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr><th>日志文件</th><th>大小</th><th>修改时间</th><th class="text-end">操作</th></tr>
                        </thead>
                        <tbody id="log-file-list">
                            <tr><td colspan="4" class="text-center py-4 text-muted">加载中...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="alert alert-info small mb-0">
            <i class="bi bi-info-circle me-2"></i>
            每个配置文件对应独立的日志文件。备份日志格式为 <code>factorio-{配置名}-{时间戳}.log</code>，超过7天的备份会自动清理。
        </div>
    </div>

    <!-- ========== 系统设置 ========== -->
    <div id="view-settings" class="view-panel">
        <div class="page-header">
            <h4><i class="bi bi-gear me-2 text-secondary"></i>系统设置</h4>
            <p class="text-muted mb-0 small">用户管理、密码修改、界面设置</p>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header"><i class="bi bi-person-gear me-2"></i>用户管理</div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label text-muted small">用户账户</label>
                                <div class="fw-bold fs-5" id="settings-username">--</div>
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">账户类型</label>
                                <div class="fw-bold fs-5"><span class="badge bg-primary" id="settings-role">--</span></div>
                            </div>
                        </div>
                        <hr>
                        <div class="mb-3">
                            <label class="form-label">修改密码</label>
                            <input type="password" class="form-control mb-2" id="settings-new-password" placeholder="新密码（至少6位）">
                            <input type="password" class="form-control" id="settings-confirm-password" placeholder="确认密码">
                        </div>
                        <button class="btn btn-primary" onclick="changePassword()"><i class="bi bi-check-lg me-1"></i>保存密码</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header"><i class="bi bi-palette me-2"></i>界面设置</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">主题风格</label>
                            <select class="form-select" id="settings-theme">
                                <option value="default">默认风格</option>
                                <option value="industrial">现代风格</option>
                                <option value="factorio">Factorio风格</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-12 mb-4">
                <div class="card">
                    <div class="card-header"><i class="bi bi-info-circle me-2"></i>系统信息</div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tr><td class="text-muted">版本</td><td>Factorio Server Pro v2.0</td></tr>
                            <tr><td class="text-muted">PHP 版本</td><td id="settings-php-version">--</td></tr>
                            <tr><td class="text-muted">服务器时间</td><td id="settings-server-time">--</td></tr>
                            <tr><td class="text-muted">操作系统</td><td id="settings-os">--</td></tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-people me-2"></i>用户列表</span>
                <button class="btn btn-sm btn-primary" onclick="showAddUserModal()"><i class="bi bi-plus-lg me-1"></i>添加用户</button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr><th>用户名</th><th>显示名称</th><th>账户类型</th><th>密码状态</th><th class="text-end">操作</th></tr>
                        </thead>
                        <tbody id="user-list-body">
                            <tr><td colspan="5" class="text-center py-3 text-muted">加载中...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>


<!-- ===== Modals ===== -->

<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="user-modal-title"><i class="bi bi-person-plus me-2"></i>添加用户</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="edit-username">
                <div class="mb-3">
                    <label class="form-label">用户名 <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="user-username" placeholder="3-20位字母、数字或下划线">
                </div>
                <div class="mb-3">
                    <label class="form-label">显示名称</label>
                    <input type="text" class="form-control" id="user-display-name" placeholder="用户显示名称">
                </div>
                <div class="mb-3">
                    <label class="form-label">账户类型</label>
                    <select class="form-select" id="user-role">
                        <option value="user">普通用户</option>
                        <option value="admin">管理员</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">密码 <span class="text-danger" id="password-required">*</span></label>
                    <input type="password" class="form-control" id="user-password" placeholder="至少6位">
                    <div class="form-text" id="password-hint">新用户必须设置密码</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()"><i class="bi bi-check-lg me-1"></i>保存</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="progressModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title" id="progressModalLabel">操作进度</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="progressModalClose" disabled></button></div>
            <div class="modal-body">
                <div class="mb-2" id="progressMessage">准备中...</div>
                <div class="progress" style="height: 20px;"><div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" id="progressBar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div></div>
                <div class="mt-2 text-end text-muted" id="progressDetails"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" id="progressModalCancel" disabled>取消</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modPortalModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><div class="modal-header bg-dark text-white"><h5 class="modal-title">Mod 门户</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="input-group mb-3"><span class="input-group-text">授权</span><input type="text" id="factorio-user" class="form-control" placeholder="用户名"><input type="password" id="factorio-token" class="form-control" placeholder="Token"></div><div class="input-group mb-3"><input type="text" id="portal-search" class="form-control" placeholder="输入 Mod 名字..." onkeydown="if(event.keyCode==13) searchModPortal()"><button class="btn btn-dark" onclick="searchModPortal()">搜索</button></div><div id="portal-results" class="list-group"></div></div></div></div></div>

<div class="modal fade" id="updateModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">更新服务</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body text-center"><div class="row mb-3"><div class="col-6 border-end"><h6>稳定版</h6><h4 id="ver-stable" class="text-success">...</h4><button class="btn btn-sm btn-outline-success" onclick="installVer($('#ver-stable').text())">安装</button></div><div class="col-6"><h6>实验版</h6><h4 id="ver-exp" class="text-warning">...</h4><button class="btn btn-sm btn-outline-warning" onclick="installVer($('#ver-exp').text())">安装</button></div></div><div id="update-log" class="alert alert-secondary d-none text-start small"></div></div></div></div></div>

<div class="modal fade" id="itemModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-box-seam me-2"></i>Factorio 物品库 (2.0 + Space Age, 560+ 物品)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-3">
                <input type="text" id="item-search" class="form-control mb-3" placeholder="搜索物品（支持中文/英文模糊匹配）..." onkeyup="filterItems()" autocomplete="off">
                <ul class="nav nav-tabs mb-0" id="itemTabs">
                    <li class="nav-item"><button class="nav-link active" onclick="renderItems('logistics', this)">物流</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderItems('production', this)">生产</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderItems('combat', this)">战斗</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderItems('intermediate', this)">中间产品</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderItems('space-age', this)">太空时代</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderItems('equipment', this)">装备模块</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderItems('other', this)">其他</button></li>
                </ul>
                <div id="item-grid" class="item-grid"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="giftItemModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white"><h5 class="modal-title"><i class="bi bi-gift me-2"></i>选择礼包物品</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-3">
                <input type="text" id="gift-item-search" class="form-control mb-3" placeholder="搜索物品（支持中文/英文模糊匹配）..." onkeyup="filterGiftItems()" autocomplete="off">
                <ul class="nav nav-tabs mb-0" id="giftItemTabs">
                    <li class="nav-item"><button class="nav-link active" onclick="renderGiftItems('logistics', this)">物流</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderGiftItems('production', this)">生产</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderGiftItems('combat', this)">战斗</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderGiftItems('intermediate', this)">中间产品</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderGiftItems('space-age', this)">太空时代</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderGiftItems('equipment', this)">装备模块</button></li>
                    <li class="nav-item"><button class="nav-link" onclick="renderGiftItems('other', this)">其他</button></li>
                </ul>
                <div id="gift-item-grid" class="item-grid"></div>
            </div>
            <div class="modal-footer"><small class="text-muted me-auto">点击物品添加到礼包列表</small><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">关闭</button></div>
        </div>
    </div>
</div>

<div id="toast-container" class="position-fixed bottom-0 end-0 p-3 z-index-9999"></div>

<script src="/lib/vendor/bootstrap/js/bootstrap.bundle.js"></script>
<script src="/app/public/assets/js/jquery-3.6.0.min.js"></script>
<script src="/app/public/assets/js/app.bundle.js"></script>
<script>
// ========== 导航切换 ==========
function switchView(viewName) {
    document.querySelectorAll('.view-panel').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.sidebar-nav-item').forEach(item => item.classList.remove('active'));

    const target = document.getElementById(`view-${viewName}`);
    if (target) target.classList.add('active');

    document.querySelectorAll(`.sidebar-nav-item[data-view="${viewName}"]`).forEach(item => item.classList.add('active'));

    if (viewName === 'settings') loadSettingsInfo();
    if (viewName === 'mods') loadMods();
    if (viewName === 'files') loadFileLists();
    if (viewName === 'logs') refreshLogList();
    if (viewName === 'players') loadPlayerLists();
    if (viewName === 'responder') loadAutoResponderStatus();
}

document.addEventListener('DOMContentLoaded', () => {
    checkAuth();

    document.querySelectorAll('.sidebar-nav-item[data-view]').forEach(item => {
        item.addEventListener('click', e => {
            e.preventDefault();
            switchView(item.dataset.view);
        });
    });

    probe();
});

// ========== 认证 ==========
async function checkAuth() {
    try {
        const res = await fetch('../../api.php?action=check_auth');
        const d = await res.json();
        if (!d.authenticated) window.location.href = 'login.html';
        else document.getElementById('current-user').textContent = d.user?.name || '管理员';
    } catch (e) { window.location.href = 'login.html'; }
}

function logout() {
    fetch('../../api.php?action=logout', { method: 'POST' }).then(() => window.location.href = 'login.html');
}

function showToast(msg, type = 'info') {
    const bg = type === 'error' ? 'bg-danger' : type === 'success' ? 'bg-success' : 'bg-primary';
    const t = document.createElement('div');
    t.className = `toast align-items-center text-white ${bg} border-0 show`;
    t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
    document.getElementById('toast-container').appendChild(t);
    setTimeout(() => t.remove(), 3500);
}

function escapeHtml(str) { return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escapeAttr(str) { return str.replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }

// ========== 系统探针 ==========
let serverStateLock = false;
async function probe() {
    if (serverStateLock) return;
    try {
        const res = await fetch('/app/api.php?action=rcon_status');
        const d = await res.json();
        updateAppStatus(d.running, d.connected);
    } catch(e) { console.error('probe error', e); }
    setTimeout(probe, 8000);
}
function updateAppStatus(running, connected) {
    const badge = document.getElementById('server-status-badge');
    const stopArea = document.getElementById('stop-area');
    const startForm = document.getElementById('startForm');
    if (running) {
        badge.className = 'badge bg-success'; badge.innerHTML = '<i class="bi bi-circle-fill me-1"></i>运行中';
        stopArea.classList.remove('d-none'); startForm.classList.add('d-none');
    } else {
        badge.className = 'badge bg-secondary'; badge.innerHTML = '<i class="bi bi-circle me-1"></i>未运行';
        stopArea.classList.add('d-none'); startForm.classList.remove('d-none');
    }
}
async function controlServer(action) {
    serverStateLock = true;
    showToast(action === 'start' ? '正在启动...' : '正在停止...', 'info');
    const fd = new FormData(); fd.append('action', action); fd.append('server', 'default');
    try {
        const res = await fetch('/app/api.php', { method:'POST', body:fd });
        const d = await res.json(); showToast(d.message || (action==='start'?'启动成功':'停止成功'), 'success');
    } catch(e) { showToast('操作失败: '+e.message, 'error'); }
    setTimeout(() => { serverStateLock = false; probe(); }, 4000);
}
async function saveGame() {
    const fd = new FormData(); fd.append('action','save_game'); fd.append('server','default');
    try {
        const res = await fetch('/app/api.php',{method:'POST',body:fd}); const d = await res.json();
        showToast(d.message || '存档请求已发送', 'success');
    } catch(e) { showToast('存档失败: '+e.message, 'error'); }
}

// ========== 启动选项 ==========
async function loadStartOptions() {
    try {
        const [vRes,mRes] = await Promise.all([
            fetch('/app/api.php?action=get_versions'),
            fetch('/app/api.php?action=files&type=map')
        ]);
        const vData = await vRes.json(), mData = await mRes.json();

        const vs = document.getElementById('version-select'); vs.innerHTML = '<option value="">-- 请选择版本 --</option>';
        (vData.versions||[]).forEach(v => vs.innerHTML += `<option value="${v.id}">${v.name}</option>`);

        const ms = document.getElementById('map-select'); ms.innerHTML = '<option disabled>加载中...</option>';
        if (mData.files && Array.isArray(mData.files)) {
            ms.innerHTML = '<option value="">-- 请选择存档 --</option>';
            mData.files.forEach(f => { const n=f.filename||f.name||f; ms.innerHTML+=`<option value="${n}">${f.display||n}</option>`; });
        }
        const cs = document.getElementById('config-select'); cs.innerHTML = '<option disabled>加载中...</option>';

        const cRes = await fetch('/app/api.php?action=files&type=config');
        const cData = await cRes.json();
        cs.innerHTML = '<option value="">-- 请选择配置 --</option>';
        if (cData.files && Array.isArray(cData.files)) {
            cData.files.forEach(f => { const n=f.filename||f.name||f; cs.innerHTML+=`<option value="${n}">${f.display||n}</option>`; });
        }
    } catch(e) { console.error('loadStartOptions error',e); }
}
function refreshMapList() { loadStartOptions(); loadSaveHistory(); }
function refreshConfigList() { loadStartOptions(); }
function updateConfigEditLink() {
    const v = document.getElementById('config-select').value;
    document.getElementById('config-edit-link').href = v ? `../../configEditor.php?config=${encodeURIComponent(v)}` : '../../configEditor.php';
}
async function checkUpdate() {
    showToast('正在检查更新...','info');
    try {
        const r = await fetch('../../api.php?action=update_check'); const d = await r.json();
        if(d.has_update) showToast(`发现新版本: ${d.latest_version}`,'success');
        else showToast('已是最新版本','success');
    } catch(e) { showToast('检查更新失败','error'); }
}
async function installVer(ver) {
    if(!confirm(`确定要安装 ${ver} 吗？`)) return;
    const fd=new FormData(); fd.append('action','update_install'); fd.append('version',ver);
    try {
        const r=await fetch('../../api.php',{method:'POST',body:fd}); const d=await r.json();
        showToast(d.message||'安装完成','success'); setTimeout(()=>loadStartOptions(),3000);
    } catch(e){showToast('安装失败:'+e.message,'error')}
}
async function loadSaveHistory() {
    try {
        const r=await fetch('/app/api.php?action=files&type=map'); const d=await r.json();
        const el=document.getElementById('save-history');
        if(!d.files||!d.files.length){el.innerHTML='<div class="text-center text-muted py-3 small">暂无存档</div>';return;}
        el.innerHTML=d.files.map(f=>`<div class="list-group-item list-group-action d-flex justify-content-between align-items-center${f.is_current?' active':''}" onclick="switchSave('${escapeAttr(f.filename)}')"><div><div class="fw-bold">${escapeHtml(f.display||f.filename)}</div><small class="text-muted">${(f.size||0).toFixed(1)} MB</small></div>${f.is_current?'<span class="badge bg-success ms-2">当前</span>':''}</div>`).join('');
    }catch(e){console.error(e)}
}
async function switchSave(filename){
    if(!filename)return;
    const fd=new FormData();fd.append('action','set_current_save');fd.append('filename',filename);
    try{
        const r=await fetch('/app/api.php',{method:'POST',body:fd});const d=await r.json();
        showToast(d.message||'切换成功','success');setTimeout(()=>{loadSaveHistory();probe()},2000);
    }catch(e){showToast('切换失败:'+e.message,'error')}
}

// ========== 模组 ==========
function loadMods(){
    fetch('/app/api.php?action=mod_list').then(r=>r.json()).then(d=>{
        const el=document.getElementById('mod-list');
        if(!d.mods){el.innerHTML='<div class="text-center text-muted p-3">加载失败</div>';return;}
        el.innerHTML=d.mods.map(m=>`
            <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                <div class="d-flex align-items-center">
                    <span class="me-2">${m.enabled?'<i class="bi bi-check-circle-fill text-success"></i>':'<i class="bi bi-x-circle text-muted"></i>'}</span>
                    <span>${m.name}</span>
                </div>
                <div class="d-flex align-items-center gap-1">
                    <span class="text-muted small">${(m.size||0).toFixed(1)} KB</span>
                    <button class="btn btn-sm ${m.enabled?'btn-warning':'btn-success'}" onclick="toggleMod('${escapeAttr(m.name)}',${!m.enabled})" title="${m.enabled?'禁用':'启用'}"><i class="bi ${m.enabled?'bi-pause':'bi-play'}"></i></button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteMod('${escapeAttr(m.filename)}')" title="删除"><i class="bi bi-trash"></i></button>
                </div>
            </div>`).join('');
    });
}
function filterLocalMods(){loadMods()}
function toggleMod(name,state){
    const fd=new FormData();fd.append('action','mod_toggle');fd.append('name',name);fd.append('enabled',state);
    fetch('/app/api.php',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
        showToast(d.message||(state?'已启用':'已禁用'),state?'success':'info');loadMods();
    });
}
function uploadMod(){
    const input=document.getElementById('mod-upload-input');
    if(!input.files.length){showToast('请选择文件','error');return;}
    const fd=new FormData();fd.append('action','mod_upload');
    for(let f of input.files) fd.append('file[]',f);
    fetch('/app/api.php',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
        showToast(d.message||'上传成功','success'); input.value=''; loadMods();
    });
}
function deleteMod(name){
    if(!confirm(`确定删除 ${name}?`))return;
    const fd=new FormData();fd.append('action','mod_delete');fd.append('filename',name);
    fetch('/app/api.php',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
        showToast(d.message||'删除成功','success');loadMods();
    });
}
function searchModPortal(){
    const q=document.getElementById('portal-search').value.trim();if(!q)return;
    const u=document.getElementById('factorio-user').value,t=document.getElementById('factorio-token').value;
    if(!u||!t){showToast('请先填写授权信息','error');return;}
    fetch('/app/api.php?'+new URLSearchParams({action:'mod_portal_search',q,u,t})).then(r=>r.json()).then(d=>{
        const el=document.getElementById('portal-results');el.innerHTML='';
        (d.results||[]).forEach(m=>el.innerHTML+=`<div class="list-group-item"><div class="fw-bold">${m.name}</div><div class="small text-muted">${m.title}</div><button class="btn btn-sm btn-primary float-end mt-1" onclick="installMod('${m.name}')">安装</button></div>`);
    });
}
function installMod(name){
    const u=document.getElementById('factorio-user').value,t=document.getElementById('factorio-token').value;
    fetch('/app/api.php',{method:'POST',body:new FormData([['action','mod_portal_install'],['name',name],['username',u],['token',t])})
    .then(r=>r.json()).then(d=>{showToast(d.message||'安装成功','success');});
}

// ========== 玩家 ==========
function loadPlayerLists(){
    fetch('/app/api.php?action=player_lists').then(r=>r.json()).then(d=>{
        if(d.admins) renderList('list-admins',d.admins);
        if(d.bans) renderList('list-bans',d.bans);
        if(d.whitelist) renderList('list-whitelist',d.whitelist);
        loadKnownPlayers();
    });
}
function renderList(id,list){
    const el=document.getElementById(id);if(!el)return;
    if(!list||!list.length){el.innerHTML='<div class="text-center text-muted p-2 small">暂无数据</div>';return;}
    el.innerHTML=list.map(i=>`<div class="list-group-item list-group-action small">${typeof i==='string'?i:i.name||i}</div>`).join('');
}
function doAction(act){
    const p=document.getElementById('target-player').value.trim();
    if(!p&&act!=='wl-add'&&act!=='wl-remove'){showToast('请先选择玩家','error');return;}
    let cmd='';let body=[['action',act]];
    switch(act){
        case'ban':cmd=`/ban ${p}`;break;
        case'kick':cmd=`/kick ${p}`;break;
        case'promote':cmd=`/promote ${p}`;break;
        case'unban':cmd=`/unban ${p}`;break;
        case'wl-add':case'wl-remove':cmd=(act==='wl-add'?'/whitelist add ':'/whitelist remove ')+' '+p;break;
    }
    if(cmd){body.push(['cmd',cmd]);body.push(['server','default']);}
    if(p) body.push(['player',p]);
    fetch('/app/api.php',{method:'POST',body:new FormData(body)}).then(r=>r.json()).then(d=>showToast(d.message||'操作完成','success'));
}
function doGift(){
    const p=document.getElementById('target-player').value.trim(),item=document.getElementById('gift-item').value.trim(),cnt=document.getElementById('gift-count').value;
    if(!p){showToast('请选择玩家','error');return;}if(!item){showToast('请输入物品代码','error');return;}
    fetch('/app/api.php',{method:'POST',body:new FormData([['action','console'],['cmd',`/c ${item} ${cnt} ${p}`],['server','default'])]})
    .then(r=>r.json()).then(d=>showToast(d.message||'已发送','success'));
}
function loadKnownPlayers(){
    fetch('/app/api.php?action=online_players').then(r=>r.json()).then(d=>{
        const el=document.getElementById('known-players-list');
        if(!d.players||!d.players.length){el.innerHTML='<div class="text-center text-muted small p-3">暂无玩家数据</div>';return;}
        el.innerHTML=d.players.map(p=>`<div class="list-group-item list-group-action small" onclick="selectPlayer('${escapeAttr(p.name)}')"><span class="fw-bold">${p.name}</span><span class="text-muted ms-auto small">${p.last_action||''}</span></div>`).join('');
    });
}
function selectPlayer(n){document.getElementById('target-player').value=n;}

// ========== 自动响应 ==========
function loadAutoResponderStatus(){
    fetch('/app/api.php?action=auto_responder_status').then(r=>r.json()).then(d=>{
        const b=document.getElementById('btn-toggle-auto-responder'),bd=document.getElementById('auto-responder-status-badge');
        if(d.running){b.className='btn btn-sm btn-danger';b.innerHTML='<i class="bi bi-power me-1"></i>停止';bd.className='badge bg-success';bd.textContent='运行中';}
        else{b.className='btn btn-sm btn-success';b.innerHTML='<i class="bi bi-power me-1"></i>启动';bd.className='badge bg-secondary';bd.textContent='已停止';}
    });
}
function toggleAutoResponder(){
    fetch('/app/api.php?action=auto_responder_'+(document.getElementById('auto-responder-status-badge').classList.contains('bg-success')?'stop':'start'),{method:'POST'})
    .then(r=>r.json()).then(d=>{showToast(d.message||'操作完成','success');setTimeout(loadAutoResponderStatus,1500)});
}

// ========== 文件 ==========
function loadFileLists(){
    Promise.all([
        fetch('/app/api.php?action=files&type=map'),
        fetch('/app/api.php?action=files&type=config')
    ]).then(([mr,cr])=>Promise.all([mr.json(),cr.json()])).then(([md,cd])=>{
        const ml=document.getElementById('file-list-map'),cl=document.getElementById('file-list-config');
        if(md.files)ml.innerHTML=(md.files||[]).map(f=>`<div class="list-group-item d-flex justify-content-between align-items-center"><span class="truncate">${escapeHtml(f.display||f.filename)}</span><span class="text-muted small">${((f.size||0)/1024/1024).toFixed(1)} MB</span></div>`).join('')||'<div class="text-center text-muted p-2 small">暂无存档</div>';
        if(cd.files)cl.innerHTML=(cd.files||[]).map(f=>`<div class="list-group-item d-flex justify-content-between align-items-center"><span class="truncate">${escapeHtml(f.display||f.filename)}</span><span class="text-muted small">${((f.size||0)/1024).toFixed(1)} KB</span></div>`).join('')||'<div class="text-center text-muted p-2 small">暂无配置</div>';
    });
}
document.getElementById('btn-upload')?.addEventListener('click',()=>{
    const inp=document.getElementById('file-upload');if(!inp.files.length){showToast('请选择文件','error');return;}
    const fd=new FormData();fd.append('action','upload');
    for(let f of inp.files) fd.append('file[]',f);
    fetch('/app/api.php',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{showToast(d.message||'上传成功','success');inp.value='';loadFileLists();});
});

// ========== 日志 ==========
function refreshLogList(){
    fetch('/app/api.php?action=log_files').then(r=>r.json()).then(d=>{
        const el=document.getElementById('log-file-list');
        if(!d.files||!d.files.length){el.innerHTML='<tr><td colspan="4" class="text-center py-3 text-muted">暂无日志</td></tr>';return;}
        el.innerHTML=d.files.map(f=>`<tr><td>${escapeHtml(f.filename)}</td><td>${f.size_display||'--'}</td><td>${f.modified||'--'}</td><td class="text-end">${f.is_current?'<span class="badge bg-success me-1">当前</span>':''}<button class="btn btn-sm btn-outline-primary" onclick="downloadLog('${escapeAttr(f.filename)}')">下载</button>${!f.is_current&&!f.is_backup?`<button class="btn btn-sm btn-outline-danger" onclick="deleteLog('${escapeAttr(f.filename)}')">删除</button>`:''}</td></tr>`).join('');
    });
}
function downloadLog(fn){
    window.location.href=`../../api.php?action=download_log&filename=${encodeURIComponent(fn)}`;
}
function deleteLog(fn){
    if(!confirm(`确定删除 ${fn}?`))return;
    fetch('/app/api.php',{method:'POST',body:new FormData([['action','delete_log'],['filename',fn]])}).then(r=>r.json())
    .then(d=>{showToast(d.message||'删除成功','success');refreshLogList()});
}

// ========== 设置 ==========
function loadSettingsInfo(){
    fetch('/app/api.php?action=phpinfo').then(r=>r.json()).then(d=>{
        if(d.success){document.getElementById('settings-php-version').textContent=d.php_version||'--';document.getElementById('settings-os').textContent=d.os||'--';document.getElementById('settings-server-time').textContent=d.server_time||new Date().toLocaleString();}
    });
    fetch('/app/api.php?action=get_user_info').then(r=>r.json()).then(d=>{
        if(d.success&&d.user){document.getElementById('settings-username').textContent=d.user.username||'--';const rm={admin:'管理员',user:'普通用户'};const rl=d.user.role||'user';document.getElementById('settings-role').textContent=rm[rl]||rl;document.getElementById('settings-role').className=rl==='admin'?'badge bg-primary':'badge bg-secondary';}
    });
    loadUserList();
}
function loadUserList(){
    fetch('/app/api.php?action=user_list').then(r=>r.json()).then(d=>{if(d.success)renderUserList(d.users);else document.getElementById('user-list-body').innerHTML='<tr><td colspan="5" class="text-center py-3 text-danger">加载失败</td></tr>'}).catch(()=>document.getElementById('user-list-body').innerHTML='<tr><td colspan="5" class="text-center py-3 text-danger">加载失败</td></tr>');
}
function renderUserList(users){
    const tb=document.getElementById('user-list-body');
    if(!users||!users.length){tb.innerHTML='<tr><td colspan="5" class="text-center py-3 text-muted">暂无用户</td></tr>';return;}
    const rm={admin:'管理员',user:'普通用户'};
    tb.innerHTML=users.map(u=>`<tr><td><code>${u.username}</code></td><td>${u.name||u.username}</td><td><span class="badge ${u.role==='admin'?'bg-primary':'bg-secondary'}">${rm[u.role]||u.role}</span></td><td><span class="badge ${u.has_password?'bg-success':'bg-warning'}">${u.has_password?'已设置':'未设置'}</span></td><td class="text-end"><div class="btn-group btn-group-sm"><button class="btn btn-outline-primary" onclick="editUser('${u.username}','${u.name||''}','${u.role}')"><i class="bi bi-pencil"></i></button><button class="btn btn-outline-warning" onclick="resetUserPassword('${u.username}')"><i class="bi bi-key"></i></button><button class="btn btn-outline-danger" onclick="deleteUser('${u.username}')"><i class="bi bi-trash"></i></button></div></td></tr>`).join('');
}
function showAddUserModal(){
    document.getElementById('user-modal-title').innerHTML='<i class="bi bi-person-plus me-2"></i>添加用户';
    document.getElementById('edit-username').value='';document.getElementById('user-username').value='';document.getElementById('user-username').disabled=false;
    document.getElementById('user-display-name').value='';document.getElementById('user-role').value='user';document.getElementById('user-password').value='';
    document.getElementById('password-required').style.display='inline';document.getElementById('password-hint').textContent='新用户必须设置密码';
    new bootstrap.Modal(document.getElementById('addUserModal')).show();
}
function editUser(u,n,r){
    document.getElementById('user-modal-title').innerHTML='<i class="bi bi-pencil me-2"></i>编辑用户';
    document.getElementById('edit-username').value=u;document.getElementById('user-username').value=u;document.getElementById('user-username').disabled=true;
    document.getElementById('user-display-name').value=n;document.getElementById('user-role').value=r;document.getElementById('user-password').value='';
    document.getElementById('password-required').style.display='none';document.getElementById('password-hint').textContent='留空则不修改密码';
    new bootstrap.Modal(document.getElementById('addUserModal')).show();
}
function saveUser(){
    const eu=document.getElementById('edit-username').value,u=document.getElementById('user-username').value.trim(),dn=document.getElementById('user-display-name').value.trim(),r=document.getElementById('user-role').value,pw=document.getElementById('user-password').value;
    if(!u){showToast('请输入用户名','error');return;}if(!eu&&!pw){showToast('新用户必须设置密码','error');return;}if(pw&&pw.length<6){showToast('密码长度至少6位','error');return;}
    const fd=new FormData();
    if(eu){fd.append('action','update_user_info');fd.append('username',eu);if(dn)fd.append('name',dn);fd.append('role',r);if(pw)fd.append('new_password',pw);}
    else{fd.append('action','add_user');fd.append('username',u);fd.append('password',pw);fd.append('name',dn||u);fd.append('role',r);}
    fetch('/app/api.php',{method:'POST',body:fd}).then(res=>res.json()).then(d=>{if(d.success){showToast(d.message||'保存成功','success');bootstrap.Modal.getInstance(document.getElementById('addUserModal')).hide();loadUserList();}else showToast(d.error||'保存失败','error');}).catch(e=>showToast('保存失败: '+e.message,'error'));
}
function deleteUser(u){if(!confirm(`确定删除 "${u}"?`))return;fetch('/app/api.php',{method:'POST',body:new FormData([['action','delete_user'],['username',u]])}).then(r=>r.json()).then(d=>{if(d.success){showToast(d.message||'删除成功','success');loadUserList();}else showToast(d.error||'删除失败','error');});}
function resetUserPassword(u){const np=prompt(`${u} 新密码（至少6位）：`);if(!np)return;if(np.length<6){showToast('密码至少6位','error');return;}fetch('/app/api.php',{method:'POST',body:new FormData([['action','reset_password'],['username',u],['new_password',np)])}).then(r=>r.json()).then(d=>{if(d.success)showToast(d.message||'重置成功','success');else showToast(d.error||'重置失败','error');});}
function changePassword(){
    const np=document.getElementById('settings-new-password').value,cp=document.getElementById('settings-confirm-password').value;
    if(!np){showToast('请输入新密码','error');return;}if(np.length<6){showToast('密码至少6位','error');return;}if(np!==cp){showToast('两次不一致','error');return;}
    fetch('/app/api.php',{method:'POST',body:new FormData([['action','change_password'],['new_password',np],['confirm_password',cp)])}).then(r=>r.json()).then(d=>{if(d.success){showToast(d.message||'修改成功','success');document.getElementById('settings-new-password').value='';document.getElementById('settings-confirm-password').value='';}else showToast(d.error||'修改失败','error');});
}

// ========== 自动响应详情函数（从index.js迁移的精简版）==========
function addServerResponse(){showToast('请在下方配置参数后添加','info');}
function scheduleChatMessage(){showToast('请填写消息内容和时间','info');}
function addTriggerResponse(){const k=document.getElementById('trigger-keyword').value,r=document.getElementById('trigger-response').value;if(!k||!r){showToast('请填写关键词和响应内容','error');return;}showToast('关键词回复已添加（演示）','success');}
function updatePlayerEvents(){showToast('玩家事件设置已更新','info');}
function openGiftItemSelector(type){bootstrap.Modal.getInstance(document.getElementById('giftItemModal'))?.hide();bootstrap.Modal.getOrCreateInstance(document.getElementById('itemModal'))?.show();}
function renderGiftItems(cat, clickedBtn) {
    const g = document.getElementById('gift-item-grid');
    if (!g) return;
    g.innerHTML = '';
    const items = (typeof ITEMS !== 'undefined') ? (ITEMS[cat] || {}) : {};
    for (const [code, name] of Object.entries(items)) {
        const b = document.createElement('button');
        b.className = 'btn btn-outline-primary item-btn h-100';
        b.innerHTML = `<div class="fw-bold small">${escapeHtml(name)}</div><div class="text-muted small font-monospace">${escapeHtml(code)}</div>`;
        b.onclick = () => {
            const input = document.getElementById('gift-item');
            if (input) input.value = code;
            const m = document.getElementById('giftItemModal');
            if (m) bootstrap.Modal.getInstance(m)?.hide();
        };
        g.appendChild(b);
    }
    if (Object.keys(items).length === 0) g.innerHTML = '<div class="text-center text-muted p-4">暂无物品</div>';
    document.querySelectorAll('#giftItemTabs .nav-link').forEach(btn => btn.classList.remove('active'));
    if (clickedBtn) clickedBtn.classList.add('active');
    else { const firstTab = document.querySelector('#giftItemTabs .nav-link'); if (firstTab) firstTab.classList.add('active'); }
}
function filterGiftItems() {
    const t = document.getElementById('gift-item-search');
    const g = document.getElementById('gift-item-grid');
    if (!t || !g || typeof ITEMS === 'undefined') return;
    const q = t.value.toLowerCase().trim();
    g.innerHTML = '';
    let found = 0;
    for (const cat in ITEMS) {
        for (const [code, name] of Object.entries(ITEMS[cat])) {
            if (!q || code.includes(q) || name.toLowerCase().includes(q)) {
                const b = document.createElement('button');
                b.className = 'btn btn-outline-primary item-btn h-100';
                b.innerHTML = `<div class="fw-bold small">${escapeHtml(name)}</div><div class="text-muted small font-monospace">${escapeHtml(code)}</div>`;
                b.onclick = () => {
                    const input = document.getElementById('gift-item');
                    if (input) input.value = code;
                    const m = document.getElementById('giftItemModal');
                    if (m) bootstrap.Modal.getInstance(m)?.hide();
                };
                g.appendChild(b);
                found++;
            }
        }
    }
    if (found === 0) g.innerHTML = '<div class="col-12 text-center text-muted py-4"><i class="bi bi-search fs-1 mb-2"></i><p class="mb-0">未找到匹配物品</p></div>';
}

// 初始化
loadStartOptions();
loadSaveHistory();
</script>
</body>
</html>